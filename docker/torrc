# ─── Tor Configuration for Robin AI ──────────────────────────────────
# Optimized for anonymous dark web scraping with Streamlit

SocksPort 0.0.0.0:9050
ControlPort 9051

# Authentication (disable for container — use network isolation instead)
CookieAuthentication 1
CookieAuthFile /var/lib/tor/control_auth_cookie
CookieAuthFileGroupReadable 1

# Logging
Log notice file /var/log/tor/notices.log

# Data directory
DataDirectory /var/lib/tor

# Circuit configuration
CircuitBuildTimeout 30
LearnCircuitBuildTimeout 0
MaxCircuitDirtiness 600
NewCircuitPeriod 300

# Performance
NumEntryGuards 3
UseEntryGuards 1
EntryNodes {US},{DE},{NL},{GB},{CA}
ExitNodes {us},{de},{nl},{gb},{ca},{fr},{ch},{se},{no},{dk}
StrictNodes 0

# DNS
DNSPort 0
AutomapHostsOnResolve 1
AutomapHostsSuffixes .onion,.exit,.i2p

# Bandwidth
BandwidthRate 2 MB
BandwidthBurst 4 MB

# Privacy
SafeLogging 1
DisableDebuggerAttachment 0

# Bridges (uncomment if needed for censorship circumvention)
# UseBridges 1
# Bridge obfs4 <IP>:<PORT> <FINGERPRINT> cert=<CERT> iat-mode=0

# Exit policies (reject everything — we only use .onion proxying)
ExitPolicy reject *:*
ExitRelay 0